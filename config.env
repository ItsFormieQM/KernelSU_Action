KERNEL_SOURCE=https://github.com/LineageOS/android_kernel_samsung_sm8250
KERNEL_SOURCE_BRANCH=lineage-23.2
KERNEL_CONFIG=gki_defconfig
KERNEL_ARCH=arm64
