KERNEL_SOURCE=https://github.com/LineageOS/android_kernel_samsung_sm8250
KERNEL_SOURCE_BRANCH=lineage-23.2
KERNEL_CONFIG=gki_defconfig
KERNEL_IMAGE_NAME=Image
ARCH=arm64

# Toolchain configurations (Fixed to prevent 404 errors)
USE_CUSTOM_CLANG=false
CLANG_BRANCH=main
CLANG_VERSION=r487747c

# Cross-compilers required by legacy setup blocks in sm8250 trees
ENABLE_GCC_ARM64=true
ENABLE_GCC_ARM32=true

# Device-specific fragments and additions
EXTRA_CMDS=vendor/samsung/r8q.config
DISABLE_CC_WERROR=true

# KernelSU integration configuration
ENABLE_KERNELSU=true
KERNELSU_TAG=v0.9.5
ADD_KPROBES_CONFIG=true

# Automatic boot.img unpacking and repacking
BUILD_BOOT_IMG=true
SOURCE_BOOT_IMAGE=https://raw.githubusercontent.com/ItsFormieQM/r8q-kernelsu-lineageos_23.2/main/boot.img
